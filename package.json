{
  "name": "video-room",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/generate-certs.mjs && node scripts/free-ports.mjs",
    "certs": "node scripts/generate-certs.mjs",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:wss\"",
    "dev:server": "node server/index.js",
    "dev:client": "vite",
    "dev:wss": "node scripts/wss-proxy.mjs",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "livekit:up": "docker compose up -d",
    "livekit:down": "docker compose down"
  },
  "dependencies": {
    "express": "^4.21.2",
    "http-proxy": "^1.18.1",
    "livekit-client": "^2.9.1",
    "livekit-server-sdk": "^2.9.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "vite": "^6.2.0"
  }
}
